generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Role: USER | STUDENT | ADMIN
// Category: QANUNVERICILIK | MANTIQ | AZERBAYCAN_DILI | INFORMATIKA
// QuizType: SINAQ | TEST
// Visibility: PUBLIC | STUDENT_ONLY

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER")
  image     String?
  active    Boolean  @default(true)
  results   Result[]
  createdAt DateTime @default(now())
}

model Quiz {
  id         String     @id @default(cuid())
  title      String
  category   String
  type       String
  duration   Int?
  visibility String     @default("PUBLIC")
  active     Boolean    @default(true)
  questions  Question[]
  results    Result[]
  createdAt  DateTime   @default(now())

  @@index([active, createdAt])
  @@index([category, active])
  @@index([type, active])
  @@index([visibility, active])
}

model Question {
  id            String  @id @default(cuid())
  quizId        String
  quiz          Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text          String
  imageUrl      String?
  options       String
  correctOption String
  order         Int     @default(0)
}

model Result {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score     Int
  correct   Int
  wrong     Int
  skipped   Int
  answers   String
  createdAt DateTime @default(now())

  @@index([quizId, score])
  @@index([userId, createdAt])
}

model Material {
  id         String   @id @default(cuid())
  title      String
  category   String
  fileUrl    String
  fileType   String
  visibility String   @default("PUBLIC")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([active, createdAt])
  @@index([category, active])
  @@index([visibility, active])
}

model Article {
  id        String   @id @default(cuid())
  title     String
  content   String
  summary   String   @default("")
  imageUrl  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active, createdAt])
}

model SiteSettings {
  id           String @id @default("main")
  heroTitle    String @default("Biliklərinizi Test Edin")
  heroBadge    String @default("Ulvi Asad — İnteraktiv Təhsil Platforması")
  heroSubtitle String @default("Qanunvericilik, məntiq, Azərbaycan dili, informatika və DQ Qəbul sahələrində quiz və testlərlə özünüzü sınayın. Materiallar yükləyin, məqalələr oxuyun.")
  contactEmail String @default("info@muellim.az")
  contactPhone String @default("+994 50 000 00 00")
  contactAddress String @default("Bakı, Azərbaycan")
  facebook     String @default("")
  instagram    String @default("")
  youtube      String @default("")
  updatedAt    DateTime @updatedAt
}
