generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Role: USER | STUDENT | TEACHER | ADMIN
// Category: QANUNVERICILIK | MANTIQ | AZERBAYCAN_DILI | INFORMATIKA | DQ_QEBUL
// QuizType: SINAQ | TEST
// Visibility: PUBLIC | STUDENT_ONLY

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER")
  image     String?
  active    Boolean  @default(true)
  results   Result[]
  createdAt DateTime @default(now())

  // TEACHER → STUDENT əlaqəsi
  // Tələbənin müəllimi (yalnız STUDENT rolunda olan userlər üçün)
  teacherId   String?
  teacher     User?   @relation("TeacherStudents", fields: [teacherId], references: [id])
  // Müəllimin tələbələri (yalnız TEACHER rolunda olan userlər üçün)
  students    User[]  @relation("TeacherStudents")

  // Müəllimin yaratdığı quizlər
  createdQuizzes Quiz[] @relation("QuizCreator")

  // İstifadəçinin yaratdığı AI botlar
  createdBots    AiBot[] @relation("UserBots")

  // Müəllimin adminə göndərdiyi sorğular
  requests       Request[] @relation("TeacherRequests")

  @@index([teacherId])
}

model Quiz {
  id         String     @id @default(cuid())
  title      String
  category   String
  type       String
  duration   Int?
  visibility String     @default("PUBLIC")
  active     Boolean    @default(true)
  questions  Question[]
  results    Result[]
  createdAt  DateTime   @default(now())

  // Quizi yaradan müəllim/admin (null = köhnə quizlər, admin tərəfindən yaradılmış)
  createdById String?
  createdBy   User?   @relation("QuizCreator", fields: [createdById], references: [id])

  // Mətn əsaslı quiz (METN tipi) üçün passage sahələri
  passageTitle    String?   // Passage başlığı (isteğe bağlı)
  passageContent  String?   // Passage HTML mətni (METN tipi üçün şərti məcburi)
  passageImageUrl String?   // Passage başlıq şəklinin URL-i (isteğe bağlı)

  @@index([active, createdAt])
  @@index([category, active])
  @@index([type, active])
  @@index([visibility, active])
  @@index([createdById])
}

model Question {
  id            String  @id @default(cuid())
  quizId        String
  quiz          Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text          String
  imageUrl      String?
  options       String
  correctOption String
  order         Int     @default(0)
  points        Int     @default(1)
  // Açıq sual dəstəyi
  questionType        String  @default("CHOICE")  // CHOICE | OPEN
  openAnswerExample   String?                      // Admin tərəfindən nümunə cavab (placeholder)
}

model Result {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score     Int
  correct   Int
  wrong     Int
  skipped   Int
  answers   String
  createdAt DateTime @default(now())

  @@index([quizId, score])
  @@index([userId, createdAt])
}

model Material {
  id         String   @id @default(cuid())
  title      String
  category   String
  fileUrl    String
  fileType   String
  visibility String   @default("PUBLIC")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([active, createdAt])
  @@index([category, active])
  @@index([visibility, active])
}

model Article {
  id        String   @id @default(cuid())
  title     String
  content   String
  summary   String   @default("")
  imageUrl  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active, createdAt])
}

// Dinamik kateqoriyalar — admin tərəfindən idarə olunur
model Category {
  id        String   @id @default(cuid())
  value     String   @unique  // e.g. "QANUNVERICILIK"
  label     String            // e.g. "Qanunvericilik"
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Request {
  id          String   @id @default(cuid())
  teacherId   String
  teacher     User     @relation("TeacherRequests", fields: [teacherId], references: [id])
  title       String
  message     String
  type        String   @default("GENERAL")
  // Status: PENDING | IN_PROGRESS | RESOLVED
  status      String   @default("PENDING")
  // Admin cavabı (isteğe bağlı)
  adminNote   String?
  // Əlaqəli quiz və ya user (isteğe bağlı)
  relatedQuizId String?
  relatedUserId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teacherId])
  @@index([status])
}

model SiteSettings {
  id           String @id @default("main")
  heroTitle    String @default("Biliklərinizi Test Edin")
  heroBadge    String @default("Ulvi Asad — İnteraktiv Təhsil Platforması")
  heroSubtitle String @default("Qanunvericilik, məntiq, Azərbaycan dili, informatika və DQ Qəbul sahələrində quiz və testlərlə özünüzü sınayın. Materiallar yükləyin, məqalələr oxuyun.")
  contactEmail String @default("info@muellim.az")
  contactPhone String @default("+994 50 000 00 00")
  contactAddress String @default("Bakı, Azərbaycan")
  facebook     String @default("")
  instagram    String @default("")
  youtube      String @default("")
  updatedAt    DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Certificate {
  id        String   @id @default(cuid())
  imageUrl  String
  title     String   @default("")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active, order])
}

// AI Botlar — admin tərəfindən yaradılır, quiz generasiyasında istifadə olunur
model AiBot {
  id          String   @id @default(cuid())
  name        String                        // Bot adı (məs: "Qanunvericilik Mütəxəssisi")
  description String   @default("")         // Qısa təsvir
  category    String   @default("")         // Əlaqəli kateqoriya (isteğe bağlı)
  content     String                        // Öyrətmə mətni (bilik bazası)
  prompt      String                        // Sistem promptu (AI-a verilən təlimat)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // İstifadəçi tərəfindən yaradılmış bot (null = admin botu)
  createdById String?
  createdBy   User?    @relation("UserBots", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([active])
  @@index([category])
  @@index([createdById])
}
