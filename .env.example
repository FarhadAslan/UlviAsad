# Bu faylı kopyalayıb ".env" adlandır və dəyərləri doldur
# cp .env.example .env

# ── Database (Supabase) ──────────────────────────────────────
# Supabase → Project Settings → Database → Connection string
# "Transaction" mode (port 6543) — əsas connection
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# "Session" mode (port 5432) — migration və direct queries üçün
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Google OAuth ─────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URIs: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── NextAuth ─────────────────────────────────────────────────
# İstənilən uzun random string: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Lokal üçün:
NEXTAUTH_URL="http://localhost:3000"

# ── Cloudinary (şəkil yükləmə) ───────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Email (SMTP) — parol sıfırlama üçün ─────────────────────
# Gmail nümunəsi:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=your-app-password   ← Gmail App Password (2FA aktiv olmalıdır)
#
# Digər provayderlar: Brevo (Sendinblue), Mailgun, SendGrid, vb.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM_NAME="Ulvi Asad"
SMTP_FROM_EMAIL="your@gmail.com"

# ── AI (Quiz Generator) - MULTIPLE KEY ROTATION ─────────────
# Her provider üçün 2-3 API key konfiqurasiya edə bilərsiniz
# Sistem avtomatik rotate edəcək və rate limit problemini həll edəcək

# Groq — https://console.groq.com → API Keys (pulsuz, sürətli)
# Eyni hesabdan çoxlu key ala bilərsiniz və ya fərqli email-lə yeni hesablar
GROQ_API_KEY="your-groq-api-key-1"
GROQ_API_KEY_2="your-groq-api-key-2"     # OPTIONAL: 2-ci key (rate limit 2x)
GROQ_API_KEY_3="your-groq-api-key-3"     # OPTIONAL: 3-cü key (rate limit 3x)

# Google Gemini — https://aistudio.google.com/apikey (1,500 requests/day pulsuz)
GEMINI_API_KEY="your-gemini-api-key-1"
GEMINI_API_KEY_2="your-gemini-api-key-2" # OPTIONAL: 2-ci key (rate limit 2x)
GEMINI_API_KEY_3="your-gemini-api-key-3" # OPTIONAL: 3-cü key (rate limit 3x)

# OpenRouter — https://openrouter.ai → Keys (pulsuz modellər mövcuddur)
OPENROUTER_API_KEY="your-openrouter-api-key-1"
OPENROUTER_API_KEY_2="your-openrouter-api-key-2" # OPTIONAL

# Mistral AI — https://console.mistral.ai → API Keys (1 req/sec pulsuz, EU GDPR)
MISTRAL_API_KEY="your-mistral-api-key-1"
MISTRAL_API_KEY_2="your-mistral-api-key-2"       # OPTIONAL

# Cerebras — https://cloud.cerebras.ai → API Keys (2,100 tokens/sec, ən sürətli)
CEREBRAS_API_KEY="your-cerebras-api-key-1"
CEREBRAS_API_KEY_2="your-cerebras-api-key-2"     # OPTIONAL

# HuggingFace — https://huggingface.co/settings/tokens (100+ model, rate limited)
HUGGINGFACE_API_KEY="your-huggingface-api-key-1"
HUGGINGFACE_API_KEY_2="your-huggingface-api-key-2" # OPTIONAL

# NOT: _2 və _3 key-lər OPTIONAL-dır. Hər əlavə key rate limit-i artırır.
# Tövsiyə: Hər provider üçün 2-3 key (GROQ_API_KEY + GROQ_API_KEY_2 + GROQ_API_KEY_3)
# NƏTICƏ: 2 key = 2x throughput, 3 key = 3x throughput
